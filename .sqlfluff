[sqlfluff]
dialect = tsql
templater = raw

exclude_rules = CV08,RF02,RF03,RF05
# CV08 - Use 'LEFT JOIN' instead of 'RIGHT JOIN'.  | [convention.left_join]
# RF02 - Unqualified reference 'Latin1_General_CI_AS' found in select with more than one referenced table/view | [references.qualification]
# RF03 - | Unqualified reference 'Latin1_General_CI_AS' found in | single table select. | [references.consistent]
# RF05 = Do not use special characters in identifiers. | [references.special_chars]

# when superlinter is updated change exclude_rules
# Currently   [SQLFLUFF] sqlfluff: 4.0.0
# v.4.4 - allow RF02 and RF03

prefer_quoted_identifiers = true

max_line_length = 0
large_file_skip_byte_limit = 80000


[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = pascal
unquoted_identifiers_policy = all

[sqlfluff:layout:type:alias_expression]
spacing_before = align
align_within = select_clause
spacing_after = single

[sqlfluff:indentation]
tab_space_size = 2
indent_unit = space
indented_joins = false
indented_using_on = false
implicit_indents = require
indented_on_contents = false
indented_ctes = true
template_blocks_indent = False

[sqlfluff:rules:aliasing.length]
# TODO: increase this for readability
min_alias_length = 1

[sqlfluff:rules:aliasing.table]
#aliasing.table = explicit

[sqlfluff:rules:aliasing.column]
#aliasing.column = explicit

[sqlfluff:rules:aliasing.expression]
allow_scalar = True

[sqlfluff:rules:ambiguous.join]
fully_qualify_join_types = inner

[sqlfluff:rules:ambiguous.column_references]
group_by_and_order_by_style = consistent

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = pascal

[sqlfluff:rules:jinja.padding]
single_space = true

[sqlfluff:rules:layout.spacing]
no_trailing_whitespace = true
extra_whitespace = false

[sqlfluff:rules:layout.commas]
line_position = trailing

[sqlfluff:rules:layout.functions]
no_space_after_function_name = true

[sqlfluff:rules:layout.select_targets]
wildcard_policy = single

[sqlfluff:rules:layout.set_operators]
set_operator_on_new_line = ['UNION', 'UNION ALL']

[sqlfluff:rules:structure.nested_case]

[sqlfluff:rules:structure.subquery]
forbid_subquery_in = join

# The default configuration for the not equal convention rule is "consistent"
# which will auto-detect the setting from the rest of the file. This
# is less desirable in a new project and you may find this (slightly
# more strict) setting more useful.
[sqlfluff:rules:convention.not_equal]
# Default to preferring the "ansi" (i.e. `<>`)
preferred_not_equal_style = ansi

